{
  "name": "@mr/mobile",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "clean": "yarn clean:android && yarn clean:ios && yarn clean:node-modules",
    "clean:android": "rm -rf android/build",
    "clean:ios": "rm -rf android/build && rm -rf ios/Pods && rm -rf ~/Library/Developer/Xcode/DerivedData/bds*",
    "clean:node-modules": "rm -rf node_modules",
    "start": "react-native start",
    "reverse": "adb reverse tcp:8081 tcp:8081; adb reverse tcp:9090 tcp:9090;",
    "android": "yarn reverse; react-native run-android --variant=developmentDebug",
    "ios": "react-native run-ios",
    "postinstall": "patch-package && bin/post-install.sh && yarn jetify",
    "refresh-aurora": "bin/refresh-aurora.sh",
    "test": "jest",
    "lint": "cd ../.. && eslint packages/mobile --ext .js,.jsx,.ts,.tsx",
    "lint-staged": "cd ../.. && eslint --ext .js,.jsx,.ts,.tsx",
    "build:production": "cd android && ./gradlew clean && cross-env ENVFILE=.env.production ./gradlew app:assembleRelease",
    "fastlane:android-prod": "cross-env ENVFILE=.env.production fastlane android bds_production",
    "fastlane:ios-prod": "cross-env ENVFILE=.env.production fastlane ios bds_production",
    "fastlane:android-cyan": "cross-env ENVFILE=.env.squads.cyan fastlane android bds_squads squad_id:cyan",
    "fastlane:ios-cyan": "cross-env ENVFILE=.env.squads.cyan fastlane ios bds_squads squad_id:cyan",
    "version:minor": "yarn version --minor --no-git-tag-version",
    "version:patch": "yarn version --patch --no-git-tag-version"
  },
  "dependencies": {
    "@bds/aurora": "ssh://git@github.com:gss-bds/aurora.git#068f19d0d6834921fbca311dcd12600c3b8ebb05",
    "@react-native-community/async-storage": "1.6.1",
    "@react-native-community/clipboard": "1.5.1",
    "@react-native-community/hooks": "2.5.1",
    "@react-native-community/netinfo": "4.2.2",
    "@react-native-community/toolbar-android": "react-native-community/toolbar-android",
    "async": "3.2.0",
    "axios": "0.19.2",
    "axios-auth-refresh": "2.2.0",
    "buffer": "5.6.0",
    "formik": "2.1.5",
    "haversine": "1.1.1",
    "hoist-non-react-statics": "3.3.0",
    "i18next": "19.2.0",
    "immer": "4.0.1",
    "jwt-decode": "2.2.0",
    "lodash": "4.17.20",
    "lottie-ios": "3.1.8",
    "lottie-react-native": "3.5.0",
    "map-keys-deep-lodash": "1.2.2",
    "md5": "2.2.1",
    "mobx": "5.15.4",
    "mobx-persist": "0.4.1",
    "mobx-react-lite": "2.0.4",
    "mobx-utils": "5.5.7",
    "moment": "2.24.0",
    "moment-business-days": "1.2.0",
    "moment-timezone": "0.5.31",
    "qs": "6.9.1",
    "react": "16.13.1",
    "react-i18next": "11.3.3",
    "react-native": "0.63.2",
    "react-native-adjust": "4.23.0",
    "react-native-appstate-hook": "1.0.3",
    "react-native-camera": "3.36.0",
    "react-native-config": "0.11.7",
    "react-native-dash": "0.0.11",
    "react-native-device-info": "5.4.4",
    "react-native-document-picker": "4.2.0",
    "react-native-facephi": "ssh://git@github.com:gss-bds/react-native-facephi.git#94e955c54218c68ddc8d0bd700ea7db4b83d891c",
    "react-native-fbsdk": "3.0.0",
    "react-native-fingerprint-scanner": "6.0.0",
    "react-native-fs": "2.14.1",
    "react-native-geolocation-service": "4.0.0",
    "react-native-gesture-handler": "1.6.1",
    "react-native-get-random-values": "1.4.0",
    "react-native-gifted-chat": "0.16.3",
    "react-native-haptic-feedback": "1.9.0",
    "react-native-image-picker": "2.3.3",
    "react-native-image-zoom-viewer": "3.0.1",
    "react-native-interactable": "2.0.1",
    "react-native-iphone-x-helper": "1.2.1",
    "react-native-keychain": "4.0.5",
    "react-native-linear-gradient": "2.5.6",
    "react-native-maps": "https://github.com/react-native-community/react-native-maps#3345df12bce049f96702b679dbc2b0b7f6bbac90",
    "react-native-markdown-display": "6.1.6",
    "react-native-nfc-manager": "2.1.3",
    "react-native-notifications": "3.0.0-beta.1",
    "react-native-offline": "5.2.0",
    "react-native-pdf": "6.1.2",
    "react-native-permissions": "2.0.10",
    "react-native-rate": "1.2.4",
    "react-native-reanimated": "1.9.0",
    "react-native-share": "5.1.7",
    "react-native-snap-carousel": "3.9.1",
    "react-native-static-safe-area-insets": "2.1.1",
    "react-native-svg": "12.1.0",
    "react-native-tab-view": "2.15.2",
    "react-native-vector-icons": "7.1.0",
    "react-native-view-shot": "3.0.2",
    "rn-fetch-blob": "0.12.0",
    "uuid": "8.3.0",
    "yup": "0.29.3"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "7.7.4",
    "@babel/plugin-transform-runtime": "7.6.0",
    "@types/async": "3.2.3",
    "@types/axios": "0.14.0",
    "@types/haversine": "1.1.4",
    "@types/moment": "2.13.0",
    "@types/moment-timezone": "0.5.30",
    "@types/react": "16.9.49",
    "@types/react-native": "0.63.20",
    "@types/react-native-fbsdk": "1.1.0",
    "@types/react-native-share": "3.3.0",
    "@types/react-native-snap-carousel": "3.8.2",
    "@types/react-test-renderer": "16.9.3",
    "@types/uuid": "8.3.0",
    "@types/yup": "0.29.6",
    "babel-jest": "25.5.1",
    "babel-plugin-module-resolver": "3.2.0",
    "jetifier": "1.6.4",
    "metro-react-native-babel-preset": "0.63.0",
    "patch-package": "6.2.0",
    "postinstall-postinstall": "2.1.0",
    "react-native-debugger-open": "0.3.24",
    "react-test-renderer": "16.13.1"
  },
  "jest": {
    "preset": "react-native",
    "testMatch": [
      "**/*.test.js?(x)",
      "**/*.test.ts?(x)"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/jest/setup.js"
    ],
    "setupFiles": [
      "./node_modules/react-native-gesture-handler/jestSetup.js",
      "./node_modules/@bds/aurora/jestSetup.js"
    ]
  },
  "workspaces": {
    "nohoist": [
      "react",
      "react/**",
      "react-native",
      "react-native/**",
      "react-native-*",
      "react-native-*/**",
      "@react-native-*",
      "@react-native-*/**",
      "lottie-ios",
      "lottie-ios/**",
      "lottie-react-native",
      "lottie-react-native/**"
    ]
  }
}
